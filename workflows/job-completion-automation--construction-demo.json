        0,
        300
      ],
      "webhookId": "job-complete-webhook"
    },
    {
      "parameters": {
        "jsCode": "try {\n  const body = $input.first().json.body || $input.first().json;\n  const required = ['job_id', 'customer_name', 'customer_email', 'job_type', 'technician_name', 'labor_hours', 'labor_rate', 'materials_cost'];\n  const missing = required.filter(f => body[f] === undefined || body[f] === null || body[f] === '');\n  if (missing.length > 0) {\n    throw new Error('Missing required fields: ' + missing.join(', '));\n  }\n  const labor_hours = Number(body.labor_hours);\n  const labor_rate = Number(body.labor_rate);\n  const materials_cost = Number(body.materials_cost);\n  const labor_total = labor_hours * labor_rate;\n  const materials_markup = materials_cost * 0.15;\n  const job_total = labor_total + materials_cost + materials_markup;\n  const is_emergency = body.is_emergency === true || body.is_emergency === 'true';\n  const priority = is_emergency ? 'EMERGENCY' : 'STANDARD';\n  const ts = body.completion_timestamp || new Date().toISOString();\n  const dateObj = new Date(ts);\n  const completion_date = dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });\n  return [{ json: { job_id: body.job_id, customer_name: body.customer_name, customer_email: body.customer_email, customer_phone: body.customer_phone || '', job_type: body.job_type, technician_name: body.technician_name, address: body.address || '', job_description: body.job_description || '', labor_hours, labor_rate, materials_cost, labor_total, materials_markup, job_total: Math.round(job_total * 100) / 100, is_emergency, priority, completion_timestamp: ts, completion_date } }];\n} catch (err) {\n  throw new Error('Parse & Validate failed: ' + err.message);\n}"
      },
      "id": "parse-validate",
      "name": "Parse & Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "try {\n  const d = $input.first().json;\n  const lines = [\n    '======= INVOICE - ' + d.job_type.toUpperCase() + ' SERVICE =======',\n    '',\n    'Job ID:       ' + d.job_id,\n    'Date:         ' + d.completion_date,\n    'Technician:   ' + d.technician_name,\n    'Customer:     ' + d.customer_name,\n    'Address:      ' + d.address,\n    '',\n    '--- DESCRIPTION ---',\n    d.job_description,\n    '',\n    '--- LINE ITEMS ---',\n    'Labor:              ' + d.labor_hours + ' hrs @ $' + d.labor_rate.toFixed(2) + '/hr    $' + d.labor_total.toFixed(2),\n    'Materials:                                $' + d.materials_cost.toFixed(2),\n    'Materials Markup (15%):                   $' + d.materials_markup.toFixed(2),\n    '-------------------------------------------',\n    'TOTAL DUE:                                $' + d.job_total.toFixed(2),\n    '===========================================',\n    '',\n    'Payment due within 30 days.',\n    'For questions, contact us at (212) 555-0100.',\n    'Thank you for choosing our services!'\n  ];\n  return [{ json: { ...d, invoice_text: lines.join('\\n'), invoice_generated: true } }];\n} catch (err) {\n  throw new Error('Build Invoice failed: ' + err.message);\n}"
      },
