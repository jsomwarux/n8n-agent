    {
      "parameters": {
        "jsCode": "try {\n  const error = $input.first().json;\n  const execution = error.execution || {};\n  const lastNode = execution.lastNodeExecuted || 'unknown';\n  const errorMsg = execution.error ? execution.error.message : 'Unknown error';\n  let jobId = 'unknown';\n  try {\n    const data = execution.data;\n    if (data && data.resultData && data.resultData.runData) {\n      const webhookData = data.resultData.runData['Webhook: Job Complete'];\n      if (webhookData && webhookData[0] && webhookData[0].data && webhookData[0].data.main && webhookData[0].data.main[0]) {\n        jobId = webhookData[0].data.main[0][0].json.body.job_id || 'unknown';\n      }\n    }\n  } catch(e) {}\n  return [{ json: { error_type: 'workflow_failure', failed_node: lastNode, error_message: errorMsg, job_id: jobId, timestamp: new Date().toISOString() } }];\n} catch (err) {\n  return [{ json: { error_type: 'error_handler_failure', error_message: err.message, timestamp: new Date().toISOString() } }];\n}"
