{
  "test_cases": [
    {
      "id": "test-1",
      "name": "Standard Daily Reorder Check",
      "description": "Normal business day scheduled inventory check - should identify 9 items needing reorder across 5 suppliers",
      "payload": {
        "trigger": "scheduled",
        "triggered_by": "daily-9am",
        "date": "2026-03-04"
      },
      "expected": {
        "reorder_count": 9,
        "critical_items": "ELC-001 (Wire Connectors), CLN-002 (Mop Heads)",
        "suppliers_contacted": 5,
        "email_sent": true,
        "sheets_logged": true,
        "slack_notified": true
      },
      "curl_command": "curl -s -X POST http://localhost:5678/webhook/inventory-reorder -H \"Content-Type: application/json\" -d '{\"trigger\": \"scheduled\", \"triggered_by\": \"daily-9am\", \"date\": \"2026-03-04\"}'"
    },
    {
